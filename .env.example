# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file - it is already listed in .gitignore.

# --- App ---
APP_NAME=PackVerse Platform
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
POSTGRES_USER=packverse
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=packverse

# --- Test database (Sprint P2) ---
# Optional. If unset, defaults to "${POSTGRES_DB}_test". The test suite
# never runs against POSTGRES_DB itself. Create it once with:
#   docker compose exec db createdb -U packverse packverse_test
TEST_POSTGRES_DB=packverse_test

# --- Logging ---
LOG_LEVEL=INFO
