# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file - it is already listed in .gitignore.

# --- App ---
APP_NAME=PackVerse Platform
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
POSTGRES_USER=packverse
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=packverse

# --- Test database (Sprint P2) ---
# Optional. If unset, defaults to "${POSTGRES_DB}_test". The test suite
# never runs against POSTGRES_DB itself. Create it once with:
#   docker compose exec db createdb -U packverse packverse_test
TEST_POSTGRES_DB=packverse_test

# --- Logging ---
LOG_LEVEL=INFO

# --- Auth (Sprint P3) ---
# Required for ENVIRONMENT=staging/production/test - startup fails loudly
# without one there. For ENVIRONMENT=development only, you can leave this
# unset/blank: the app auto-generates a high-entropy secret on first boot
# and appends it back to this file itself, so it's still there (and still
# valid) on your next restart. To set one explicitly instead, generate
# with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-generate-a-real-64-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
MIN_PASSWORD_LENGTH=12

# --- Storage (Sprint P4) ---
# "local" (default) writes to STORAGE_LOCAL_ROOT on disk - use this for
# development and the test suite. "s3" talks to any S3-compatible
# provider (AWS S3, MinIO, Cloudflare R2, ...) and requires every
# S3_* setting below to be non-empty - startup fails otherwise.
STORAGE_BACKEND=local

# Path is relative to the backend/ working directory, deliberately
# outside the app/ source package. Must stay gitignored - never commit
# uploaded files.
STORAGE_LOCAL_ROOT=./data/storage

# Only required when STORAGE_BACKEND=s3.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_SSL=true
S3_FORCE_PATH_STYLE=false

# 25 MiB default.
MAX_UPLOAD_SIZE_BYTES=26214400
# Comma-separated MIME allowlist. Uploads outside this list are rejected
# with 415 - see app/services/asset_service.py. Extend deliberately, not
# by adding a wildcard.
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/svg+xml,application/pdf,application/zip,application/json,font/ttf,font/otf,model/stl,application/sla,application/octet-stream

# --- LLM Gateway (Sprint P5) ---
# Unset by default - see app/llm/routing.py. An explicit "provider" in
# the request body always wins; this is only the fallback. Must be one
# of "anthropic", "openai", "fake" if set.
LLM_DEFAULT_PROVIDER=
LLM_DEFAULT_MODEL=
LLM_TIMEOUT_SECONDS=30
# Retries apply only to transient failures (timeout, rate limit,
# provider 5xx/network) - never to auth, validation, or unsupported
# model errors. Exponential backoff with jitter.
LLM_MAX_RETRIES=2
LLM_MAX_OUTPUT_TOKENS=4096
# Comma-separated subset of anthropic/openai/fake. "fake" stays enabled
# by default so POST /api/v1/llm/generate is smoke-testable with zero
# external credentials: {"provider": "fake", "model": "fake-v1", ...}.
LLM_ALLOWED_PROVIDERS=anthropic,openai,fake
# JSON alias map, e.g.:
#   {"anthropic":{"fast":"claude-3-5-haiku-20241022","quality":"claude-opus-4-20250514"}}
# Aliases resolve through this configuration only - never hardcoded.
LLM_MODEL_ALIASES={}
# JSON pricing table, e.g.:
#   {"anthropic:claude-3-5-haiku-20241022":{"input_per_1k":"0.0008","output_per_1k":"0.004"}}
# A provider/model with no entry here prices as null (see
# app/llm/pricing.py), never a fabricated cost.
LLM_PRICING_JSON={}

# Required only if you actually call the Anthropic provider (missing
# credentials fail lazily, at first use of that provider - not at
# startup, and not if you only ever use "fake").
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=

# Required only if you actually call the OpenAI-compatible provider.
# Works against OpenAI itself, OpenRouter, or any local OpenAI-compatible
# server - just point OPENAI_BASE_URL at it.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# --- MCP client (Sprint P9B) ---
# Empty by default - GET /api/v1/mcp/servers/{name}/tools is only
# reachable for names listed here. JSON array, e.g.:
#   [{"name":"my-tools","base_url":"https://mcp.example.com/mcp","auth_token":"..."}]
# "auth_token" is optional. Servers are configured here directly - there
# is no server-registration API this sprint.
MCP_SERVERS_JSON=[]
MCP_TIMEOUT_SECONDS=10

# --- Runtime tool loop (Sprint P9C1) ---
# Max LLM Gateway calls a single agent run's tool-use loop may make
# before failing instead of continuing indefinitely. Only relevant to
# agents whose configuration_json sets "mcp_server" - every other agent
# still makes exactly one call, regardless of this setting.
RUNTIME_MAX_TOOL_ITERATIONS=5
